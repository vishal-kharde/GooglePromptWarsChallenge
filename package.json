{
  "name": "monsoon-guard-ai",
  "version": "1.0.0",
  "description": "GenAI-powered monsoon preparedness and citizen assistance platform",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js --ignore public/",
    "seed": "node server/db/seed.js",
    "test": "jest --coverage --forceExit --silent",
    "test:watch": "jest --watch --no-coverage",
    "lint": "eslint server/ --ext .js --fix"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "server/**/*.js",
      "!server/db/seed.js",
      "!server/services/gemini.js",
      "!server/services/weatherService.js",
      "!server/services/database.js",
      "!server/routes/checklist.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 70,
        "lines": 65
      }
    }
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "better-sqlite3": "^11.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "uuid": "^10.0.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "eslint": "^9.7.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": "20.x"
  },
  "keywords": [
    "monsoon",
    "preparedness",
    "genai",
    "gemini",
    "weather",
    "civic-tech",
    "india",
    "emergency"
  ],
  "license": "MIT"
}
