# ============================================================
# MonsoonGuard AI — Environment Variables
# ============================================================
# GEMINI_API_KEY must be set as an environment variable in your
# deployment platform (Render, Railway, etc.) — do NOT put it here.
# ============================================================

# ---- REQUIRED (set in deployment platform env dashboard) ----
# GEMINI_API_KEY=<set this only in Render environment variables>

# ---- SERVER ----

# Server port (Render sets this automatically — do not override)
# PORT=3000

# Node environment
NODE_ENV=production

# ---- RATE LIMITING ----
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_MINUTES=15

# ---- DATABASE ----
DB_PATH=./server/db/monsoonguard.db

# ---- CORS ----
# Use * for public access, or set to your Render URL after deploy
CORS_ORIGIN=*

# ---- GEMINI ----
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_TOKENS=2048

# ---- WEATHER (Open-Meteo — no API key needed) ----
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
OPEN_METEO_GEO_URL=https://geocoding-api.open-meteo.com/v1
